<main class="page-shell">
  {% include "components/breadcrumbs.njk" %}

  <section class="page-hero">
    <div class="container page-hero-grid">
      <div class="page-hero-copy">
        <span class="page-badge"><i class="fa-solid fa-heart"></i>Women-Owned Brampton Medi Spa</span>
        <h1 class="page-hero-title">Meet the team behind Clear Skin Medi Spa</h1>
        <p class="page-hero-summary">
          Founded in 2021 by Archana Shrestha and Bineeta Shrestha, Clear Skin Medi Spa was built to make advanced skin and laser treatments feel more personal, more comfortable, and more trustworthy from the very first visit.
        </p>
        <div class="page-actions">
          <a href="{{ site.bookingUrl }}" class="btn btn-primary" target="_blank" rel="noopener">
            <i class="fa-regular fa-calendar"></i>Book A Consultation
          </a>
          <a href="/contact/" class="btn btn-outline-gold">
            <i class="fa-solid fa-location-dot"></i>Visit The Clinic
          </a>
        </div>
        <ul class="hero-highlights" role="list">
          <li><i class="fa-solid fa-circle-check"></i><span>Founded in 2021 by Archana and Bineeta Shrestha</span></li>
          <li><i class="fa-solid fa-circle-check"></i><span>Certified laser hair removal specialists with 5+ years of hands-on industry experience</span></li>
          <li><i class="fa-solid fa-circle-check"></i><span>Focused on real results, comfort, and inclusive care for all skin tones</span></li>
        </ul>
        <div class="about-stat-row">
          <div class="about-stat-card">
            <strong>2021</strong>
            <span>Clinic founded in Brampton</span>
          </div>
          <div class="about-stat-card">
            <strong>5+ Years</strong>
            <span>Medical aesthetics experience</span>
          </div>
          <div class="about-stat-card">
            <strong>7 Days</strong>
            <span>Open for flexible scheduling</span>
          </div>
        </div>
      </div>
      <div class="hero-side-stack">
        <div class="page-image-frame">
          <img src="https://clearskinmedispa.com/wp-content/uploads/elementor/thumbs/7G0A5211-scaled-qhhm7m811b5oklvtp5yd2nydilw48avlne7gpzi2cw.jpg"
               alt="Archana and Bineeta Shrestha from Clear Skin Medi Spa">
          <span class="page-image-caption"><i class="fa-solid fa-certificate"></i>Founded by Archana and Bineeta</span>
        </div>
        <div class="hero-side-card">
          <h3>What clients can expect</h3>
          <ul class="stack-list" role="list">
            <li><i class="fa-solid fa-user-group"></i><span>Warm, pressure-free consultations and honest recommendations</span></li>
            <li><i class="fa-solid fa-microscope"></i><span>Advanced treatments selected for safety, comfort, and visible results</span></li>
            <li><i class="fa-solid fa-map-location-dot"></i><span>Convenient Brampton location close to Mississauga and the GTA</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="container section-grid about-story-grid">
      <div class="section-copy">
        <span class="section-label">Our Story</span>
        <h2 class="section-title">Science-backed treatments, delivered with empathy</h2>
        <p>
          Clear Skin Medi Spa was founded with a simple belief: glowing skin and a carefree lifestyle should feel accessible, not intimidating. Archana and Bineeta built the clinic to deliver laser hair removal and personalized skincare treatments with more clarity, more comfort, and better long-term planning.
        </p>
        <p>
          Their background in laser hair removal and medical aesthetics gives them a strong grasp of the hair growth cycle, treatment timing, and how to recommend services based on the client in front of them rather than a preset sales script.
        </p>
        <p>
          That is why appointments are designed to feel calm, informative, and realistic. The goal is not to overwhelm people with options. It is to help them choose the right next step and feel genuinely supported from consultation through results.
        </p>
      </div>
      <div class="about-side-stack">
        <div class="page-image-frame about-award-frame">
          <img src="{{ site.images.foundersAward }}"
               alt="Clear Skin Medi Spa founders with award-winning clinic technology">
          <span class="page-image-caption"><i class="fa-solid fa-award"></i>Recognized for advanced laser technology</span>
        </div>
        <div class="page-image-frame page-image-frame--soft about-accent-frame">
          <img src="{{ site.images.aboutAccent }}"
               alt="Clear Skin Medi Spa brand mark from the original About page">
        </div>
        <div class="info-panel">
          <h3>What guides the clinic</h3>
          <ul class="feature-list" role="list">
            <li><i class="fa-solid fa-check"></i><span>Personalized plans instead of generic treatment menus</span></li>
            <li><i class="fa-solid fa-check"></i><span>Inclusive technology and protocols for a wide range of skin tones</span></li>
            <li><i class="fa-solid fa-check"></i><span>Comfort-first care without compromising results</span></li>
            <li><i class="fa-solid fa-check"></i><span>Long-term relationships with clients who return for maintenance and progress</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="page-section page-section--muted">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Why Clients Choose Us</span>
        <h2 class="section-title">The Clear Skin difference</h2>
        <p class="section-subtitle">Technology matters, but so do honesty, consistency, and how people feel while they are in your care.</p>
      </div>
      <div class="feature-grid feature-grid--three">
        <div class="feature-card">
          <i class="fa-solid fa-bolt"></i>
          <h3>Gold-standard technology</h3>
          <p>Soprano ICE Platinum and other advanced treatment modalities help us treat hair removal and skin goals with more confidence and flexibility.</p>
        </div>
        <div class="feature-card">
          <i class="fa-solid fa-hand-holding-heart"></i>
          <h3>Supportive consultations</h3>
          <p>Clients get realistic guidance, treatment sequencing that makes sense, and a clinic that takes questions seriously.</p>
        </div>
        <div class="feature-card">
          <i class="fa-solid fa-users"></i>
          <h3>Community-rooted care</h3>
          <p>We are proud to serve Brampton, Mississauga, Bramalea, Caledon, Georgetown, and the wider GTA from our Financial Drive location.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="container section-grid about-specialties-grid">
      <div class="section-copy">
        <span class="section-label">Clinic Specialties</span>
        <h2 class="section-title">What people usually book us for first</h2>
        <p>
          Clients usually find us for laser hair removal, skin resurfacing, facials, microneedling, and confidence-building maintenance treatments that fit busy schedules.
        </p>
        <div class="pill-grid" role="list">
          <a href="/laser-hair-removal/" class="pill-link" role="listitem">Laser Hair Removal</a>
          <a href="/hydrafacial/" class="pill-link" role="listitem">HydraFacial</a>
          <a href="/microneedling/" class="pill-link" role="listitem">Microneedling</a>
          <a href="/oxygeneo/" class="pill-link" role="listitem">OxyGeneo</a>
          <a href="/chemical-peel/" class="pill-link" role="listitem">Advanced Facial Peel</a>
          <a href="/rf-skin-tightening/" class="pill-link" role="listitem">RF Skin Tightening</a>
        </div>
      </div>
      <div class="info-panel about-visit-card">
        <h3>Visit Clear Skin Medi Spa</h3>
        <ul class="stack-list" role="list">
          <li><i class="fa-solid fa-location-dot"></i><span>{{ site.address.formatted }}</span></li>
          <li><i class="fa-solid fa-phone"></i><span>{{ site.phoneDisplay }}</span></li>
          <li><i class="fa-regular fa-clock"></i><span>Open 7 days with free plaza parking</span></li>
          <li><i class="fa-solid fa-heart"></i><span>Consultation-led care for women and men across Brampton and the GTA</span></li>
        </ul>
      </div>
    </div>
  </section>

  {% set ctaTitle = "Let us recommend the right place to start" %}
  {% set ctaText = "If you are not sure which treatment makes sense for your skin, book a consultation and we will help you map it out." %}
  {% set ctaButtonLabel = "Book Your Consultation" %}
  {% include "components/cta-band.njk" %}
</main>
