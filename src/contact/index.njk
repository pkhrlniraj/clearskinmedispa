<main class="page-shell">
  {% include "components/breadcrumbs.njk" %}

  <section class="page-hero">
    <div class="container page-hero-grid">
      <div class="page-hero-copy">
        <span class="page-badge"><i class="fa-solid fa-location-dot"></i>Visit Clear Skin Medi Spa</span>
        <h1 class="page-hero-title">Book, call, or stop by our Brampton clinic</h1>
        <p class="page-hero-summary">
          Whether you are ready to book a specific treatment or you just want help deciding where to start, our team is easy to reach and even easier to visit.
        </p>
        <div class="page-actions">
          <a href="{{ site.bookingUrl }}" class="btn btn-primary" target="_blank" rel="noopener">
            <i class="fa-regular fa-calendar"></i>Book On Fresha
          </a>
          <a href="{{ site.phoneHref }}" class="btn btn-outline-gold">
            <i class="fa-solid fa-phone"></i>Call The Clinic
          </a>
        </div>
        <ul class="hero-highlights" role="list">
          <li><i class="fa-solid fa-circle-check"></i><span>{{ site.address.formatted }}</span></li>
          <li><i class="fa-solid fa-circle-check"></i><span>Open 7 days with free parking</span></li>
          <li><i class="fa-solid fa-circle-check"></i><span>Serving Brampton, Mississauga, Bramalea, Caledon, Georgetown, and the GTA</span></li>
        </ul>
      </div>
      <div class="hero-side-stack">
        <div class="page-image-frame">
          <img src="{{ site.images.clinicTeam }}"
               alt="Clear Skin Medi Spa team and clinic environment">
          <span class="page-image-caption"><i class="fa-solid fa-location-crosshairs"></i>Financial Drive, Brampton</span>
        </div>
        <div class="hero-side-card">
          <h3>Quick contact</h3>
          <ul class="stack-list" role="list">
            <li><i class="fa-solid fa-phone"></i><a href="{{ site.phoneHref }}">{{ site.phoneDisplay }}</a></li>
            <li><i class="fa-solid fa-envelope"></i><a href="mailto:{{ site.email }}">{{ site.email }}</a></li>
            <li><i class="fa-solid fa-map-location-dot"></i><a href="{{ site.mapUrl }}" target="_blank" rel="noopener">Open in Google Maps</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="container contact-grid">
      <div class="contact-card">
        <i class="fa-solid fa-phone"></i>
        <h3>Call Us</h3>
        <p>If you want help choosing the right service, phone is the fastest way to speak with the clinic.</p>
        <p><a href="{{ site.phoneHref }}">{{ site.phoneDisplay }}</a></p>
      </div>
      <div class="contact-card">
        <i class="fa-solid fa-envelope"></i>
        <h3>Email Us</h3>
        <p>Reach out with general questions, treatment planning questions, or timing details for your next visit.</p>
        <p><a href="mailto:{{ site.email }}">{{ site.email }}</a></p>
      </div>
      <div class="contact-card">
        <i class="fa-solid fa-location-dot"></i>
        <h3>Visit The Clinic</h3>
        <p>{{ site.address.formatted }}</p>
        <p><a href="{{ site.mapUrl }}" target="_blank" rel="noopener">Get directions</a></p>
      </div>
    </div>
  </section>

  <section class="page-section page-section--muted">
    <div class="container section-grid">
      <div class="section-copy">
        <span class="section-label">Before You Visit</span>
        <h2 class="section-title">What to expect when you arrive</h2>
        <p>
          Our clinic is designed to feel polished, comfortable, and approachable. If you are booking a first appointment, plan to arrive a few minutes early so we can confirm your details and answer any last-minute questions.
        </p>
        <p>
          If you are booking a consultation, bring your main skin or treatment goals so we can recommend the most sensible next step instead of overwhelming you with options.
        </p>
      </div>
      <div class="info-panel">
        <h3>Clinic hours</h3>
        <ul class="hours-list" role="list">
          {% for row in site.hours %}
          <li><strong>{{ row.label }}</strong><span>{{ row.value }}</span></li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </section>

  {% set faqs = contactFaqs %}
  {% set faqLabel = "Contact FAQs" %}
  {% set faqTitle = "Before you book or visit" %}
  {% set faqIntro = "A few quick answers to make your first visit easier." %}
  {% include "components/faq-list.njk" %}

  {% set ctaTitle = "Ready to reserve your appointment?" %}
  {% set ctaText = "Use Fresha if you already know the treatment you want, or call us if you would like a little guidance first." %}
  {% set ctaButtonLabel = "Book On Fresha" %}
  {% include "components/cta-band.njk" %}
</main>
